# Contact email (Base64-encoded to avoid exposing it in HTML)
# Example: echo -n "hi@example.com" | base64
NEXT_PUBLIC_CONTACT_EMAIL_B64=

# Optional custom subject prefix for generated mailto links
NEXT_PUBLIC_CONTACT_MAILTO_SUBJECT=

# Canonical site origin used by metadata, sitemap, and hreflang.
# Default: https://ronchylu.com
SITE_CANONICAL_ORIGIN=

# Set to 0 / false / no / off on mirror deployments that should stay accessible
# but not compete for Google indexing. Default: 1
SITE_INDEXABLE=
